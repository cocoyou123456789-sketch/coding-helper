{
  "name": "hot100-study-notebook",
  "version": "0.1.0",
  "private": true,
  "description": "A beginner-friendly LeetCode Hot 100 coding and notes workspace.",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:ios:web": "CAPACITOR_APP=true npm run build && node scripts/copy-pyodide.mjs",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs && npm run test:backup && npm run test:bundle && npm run test:sw && npm run test:dialogs && npm run test:editor && npm run test:ide && npm run test:navigation && npm run test:runner && npm run test:storage && npm run test:tabs && npm run test:course",
    "test:backup": "node --experimental-strip-types --test tests/study-backup.test.mjs tests/note-images.test.mjs tests/mistake-book.test.mjs tests/study-data-session.test.mjs tests/backup-integration.test.mjs tests/native-storage-safety.test.mjs tests/native-storage-behavior.test.mjs",
    "test:bundle": "node --test tests/client-bundle.test.mjs",
    "test:course": "node --experimental-strip-types --test tests/course-notes.test.mjs",
    "test:dialogs": "node --test tests/dialog-focus.test.mjs",
    "test:editor": "node --experimental-strip-types --test tests/code-editor.test.mjs",
    "test:ide": "node --experimental-strip-types --test tests/practice-completion.test.mjs tests/practice-library.test.mjs tests/practice-ide.test.mjs",
    "test:navigation": "node --experimental-strip-types --test tests/navigation-state.test.mjs",
    "test:runner": "node --experimental-strip-types --test tests/run-session.test.mjs tests/execution-trace.test.mjs tests/reference-solutions.test.mjs tests/code-layer-analysis.test.mjs",
    "test:storage": "node --experimental-strip-types --test tests/study-storage.test.mjs",
    "test:sw": "node --test tests/service-worker.test.mjs",
    "test:tabs": "node --experimental-strip-types --test tests/tab-navigation.test.mjs",
    "test:ios": "npm run ios:sync && node --test tests/ios-bundle.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern ios/App/App/public",
    "ios:add": "npx cap add ios",
    "ios:sync": "npm run build:ios:web && npx cap sync ios",
    "ios:open": "npm run ios:sync && npx cap open ios",
    "ios:run": "npm run ios:sync && npx cap run ios",
    "ios:doctor": "npx cap doctor ios",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-speech-recognition": "^8.1.7",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "pyodide": "^0.28.3",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
